# =====================================================
# SIAKAD Security Configuration
# Updated: 2025-10-14
# =====================================================

# Disable directory listing
Options -Indexes

# Follow symbolic links
Options +FollowSymLinks

# Disable server signature
ServerSignature Off

# =====================================================
# PROTECT SENSITIVE FILES
# =====================================================

# Block access to .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to configuration files
<FilesMatch "\.(env|ini|log|bak|backup|sql|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to composer files
<FilesMatch "^(composer\.(json|lock)|package\.json|.*\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to git files
<FilesMatch "^\.git">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to version control files
<FilesMatch "\.(git|svn|hg|bzr)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# =====================================================
# PROTECT VENDOR AND CONFIG DIRECTORIES
# =====================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block access to vendor directory
    RewriteRule ^vendor/ - [F,L]
    
    # Block access to config directory from web
    RewriteRule ^config/ - [F,L]
    
    # Block access to logs directory
    RewriteRule ^logs/ - [F,L]

    # Trap common scan targets and force them through security middleware (index.php)
    RewriteRule .*wp-admin.* index.php [L]
    RewriteRule .*wp-login.* index.php [L]
    RewriteRule .*shell\.php.* index.php [L]
    RewriteRule .*wso\.php.* index.php [L]
    RewriteRule .*\.env.* index.php [L]
    RewriteRule .*config\.php.* index.php [L]
    RewriteRule .*actuator.* index.php [L]
</IfModule>

# Alternative if mod_rewrite not available
# Protect hidden/sensitive directories via RewriteRule (DirectoryMatch not allowed in .htaccess)
<IfModule mod_rewrite.c>
    RewriteRule ^(\.|git|svn|vendor|config|logs)/ - [F,L]
</IfModule>

# =====================================================
# PROTECT SECURITY DATA
# =====================================================

<FilesMatch "^(blocked_ips|attempts|security|jail_history|blacklist|brute_force|subnet_bans|subnet_tracking)\.(json|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect security JSON/log files (DirectoryMatch not allowed in .htaccess)
<FilesMatch "^(blocked_ips|attempts|security|jail_history|blacklist|brute_force|subnet_bans|subnet_tracking|security)\.(json|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# =====================================================
# SECURITY HEADERS
# =====================================================

<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking
    Header set X-Frame-Options "DENY"
    
    # Enable XSS protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (adjust as needed)
    Header set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.googleapis.com https://fonts.gstatic.com https://static.cloudflareinsights.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' data: https://cdnjs.cloudflare.com https://fonts.gstatic.com;"
    
    # Remove Server header (if not already disabled)
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# =====================================================
# FORCE HTTPS (Uncomment if SSL is installed)
# =====================================================

# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# =====================================================
# PROTECT AGAINST COMMON ATTACKS
# =====================================================

# Block access to PHP execution in upload directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block PHP execution in upload directories
    RewriteRule ^(mhs|dosen)/foto/.*\.php$ - [F,L]
    RewriteRule ^mhs/kk/.*\.php$ - [F,L]
</IfModule>

# Alternative PHP protection
<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#/(mhs|dosen)/foto/# || %{REQUEST_URI} =~ m#/mhs/kk/#">
        Order allow,deny
        Deny from all
    </If>
</FilesMatch>

# =====================================================
# LIMIT REQUEST SIZE (Prevent large file upload attacks)
# =====================================================

# Max upload size (adjust as needed)
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300

# =====================================================
# DISABLE PHP ERROR DISPLAY (Security)
# =====================================================

php_flag display_errors Off
php_flag display_startup_errors Off
php_value error_reporting 0

# Log errors instead (make sure logs directory exists and is writable)
php_flag log_errors On
php_value error_log logs/php_errors.log

# =====================================================
# DISABLE DANGEROUS PHP FUNCTIONS
# =====================================================

# php_value disable_functions "exec,passthru,shell_exec,system,proc_open,popen,curl_exec,curl_multi_exec,parse_ini_file,show_source"

# =====================================================
# SESSION SECURITY
# =====================================================

php_value session.cookie_httponly 1
php_value session.cookie_secure 1
php_value session.use_only_cookies 1
php_value session.cookie_samesite Strict

# =====================================================
# MISC SECURITY
# =====================================================

# Disable access to xmlrpc.php (if WordPress-like attacks)
<Files xmlrpc.php>
    Order allow,deny
    Deny from all
</Files>

# Block suspicious user agents


# =====================================================
# PROTECT AGAINST DIRECTORY TRAVERSAL
# =====================================================



# =====================================================
# PROTECT AGAINST SQL INJECTION IN URL
# =====================================================



# =====================================================
# BROWSER CACHING (Optional - for performance)
# =====================================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# =====================================================
# END OF CONFIGURATION
# =====================================================
